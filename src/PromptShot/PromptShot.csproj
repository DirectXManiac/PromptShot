<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PromptShot</RootNamespace>
    <AssemblyName>PromptShot</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Version>0.1.0</Version>
    <Authors>DirectXManiac</Authors>
    <Product>PromptShot</Product>
    <Description>Clipboard-driven screenshot helper for CLI tools</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PromptShot.Tests" />
  </ItemGroup>

</Project>
